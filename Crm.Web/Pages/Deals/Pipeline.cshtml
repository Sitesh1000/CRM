@page "/deals/pipeline"
@using Crm.Domain.Enums
@model Crm.Web.Pages.Deals.PipelineModel
@{
    ViewData["Title"] = "Pipeline";
    var stages = Enum.GetValues<DealStage>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Deals Pipeline</h3>
    <button class="btn btn-crm" data-bs-toggle="modal" data-bs-target="#dealModal" onclick="openAddModal()">Add Deal</button>
</div>

<div class="pipeline-grid">
@foreach (var stage in stages)
{
    <section class="pipeline-col">
        <header>
            <h6>@stage</h6>
            <span>@Model.Board[stage].Count</span>
        </header>
        @foreach (var deal in Model.Board[stage])
        {
            <article class="deal-card">
                <strong>@deal.Title</strong>
                <div class="small text-muted">@deal.Contact?.FirstName @deal.Contact?.LastName</div>
                <div>@deal.Amount.ToString("C0")</div>
                <div class="small">Expected: @deal.ExpectedCloseDate?.ToString("dd MMM yyyy")</div>

                <div class="d-flex gap-2 mt-2 mb-2">
                    <a class="btn btn-sm btn-outline-primary" href="/deals/details/@deal.Id">Details</a>
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#dealModal"
                            data-id="@deal.Id" data-title="@deal.Title" data-amount="@deal.Amount" data-stage="@deal.Stage" data-contactid="@deal.ContactId" data-expectedclosedate="@(deal.ExpectedCloseDate?.ToString("yyyy-MM-dd"))"
                            onclick="openEditModal(this)">Edit</button>
                    <form method="post" asp-page-handler="Delete" asp-route-id="@deal.Id" onsubmit="return confirm('Delete this deal?');">
                        <button class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </div>

                <div class="btn-group btn-group-sm mt-2 w-100">
                    @foreach (var target in stages)
                    {
                        <form method="post" asp-page-handler="Move" asp-route-id="@deal.Id" asp-route-stage="@target" class="flex-fill">
                            <button class="btn @(target == deal.Stage ? "btn-dark" : "btn-outline-secondary") w-100" type="submit">@target.ToString()[0]</button>
                        </form>
                    }
                </div>
            </article>
        }
    </section>
}
</div>

<div class="modal fade" id="dealModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <form method="post" asp-page-handler="Save">
                <div class="modal-header">
                    <h5 class="modal-title" id="dealModalTitle">Add Deal</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body row g-2">
                    <input type="hidden" asp-for="Input.Id" id="deal-id" />
                    <div class="col-md-6"><label class="form-label">Title</label><input asp-for="Input.Title" id="deal-title" class="form-control" required /></div>
                    <div class="col-md-3"><label class="form-label">Amount</label><input asp-for="Input.Amount" id="deal-amount" class="form-control" /></div>
                    <div class="col-md-3"><label class="form-label">Stage</label><select asp-for="Input.Stage" id="deal-stage" asp-items="Html.GetEnumSelectList<DealStage>()" class="form-select"></select></div>
                    <div class="col-md-6"><label class="form-label">Contact</label><select asp-for="Input.ContactId" id="deal-contactid" class="form-select"><option value="">No contact</option>@foreach (var c in Model.Contacts){<option value="@c.Id">@c.FirstName @c.LastName</option>}</select></div>
                    <div class="col-md-6"><label class="form-label">Expected Close Date</label><input asp-for="Input.ExpectedCloseDate" type="date" id="deal-expectedclosedate" class="form-control" /></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-crm">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function openAddModal(){document.getElementById('dealModalTitle').textContent='Add Deal';['id','title','amount','contactid','expectedclosedate'].forEach(x=>document.getElementById('deal-'+x).value='');document.getElementById('deal-stage').value='Qualification';}
function openEditModal(btn){document.getElementById('dealModalTitle').textContent='Edit Deal';['id','title','amount','contactid','expectedclosedate'].forEach(x=>document.getElementById('deal-'+x).value=btn.dataset[x]||'');document.getElementById('deal-stage').value=btn.dataset.stage||'Qualification';}
</script>
}
