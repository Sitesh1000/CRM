@page "/invoices/list"
@model Crm.Web.Pages.Invoices.IndexModel
@{ ViewData["Title"] = "Invoices"; }
<div class="crm-card">
 <div class="d-flex justify-content-between align-items-center mb-3"><h4 class="mb-0">Invoices List</h4><button class="btn btn-crm" data-bs-toggle="modal" data-bs-target="#invoiceModal" onclick="openAddModal()">Add Invoice</button></div>
 <div class="table-responsive"><table class="table align-middle"><thead><tr><th>Invoice #</th><th>Quote</th><th>Contact</th><th>Due</th><th>Outstanding</th><th style="width:220px">Actions</th></tr></thead><tbody>
 @foreach (var i in Model.Invoices){var outstanding=i.TotalAmount-i.PaidAmount;<tr><td>@i.InvoiceNumber</td><td>@i.Quote?.QuoteNumber</td><td>@i.Contact?.FirstName @i.Contact?.LastName</td><td>@i.DueDate?.ToString("dd MMM yyyy")</td><td class="@(outstanding>0?"text-danger":"text-success")">&#8377;@outstanding.ToString("N2")</td><td><div class="d-flex gap-2"><a class="btn btn-sm btn-outline-primary" href="/invoices/details/@i.Id">Details</a><button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#invoiceModal" data-id="@i.Id" data-invoicenumber="@i.InvoiceNumber" data-quoteid="@i.QuoteId" data-contactid="@i.ContactId" data-totalamount="@i.TotalAmount" data-paidamount="@i.PaidAmount" data-duedate="@(i.DueDate?.ToString("yyyy-MM-dd"))" onclick="openEditModal(this)">Edit</button><form method="post" asp-page-handler="Delete" asp-route-id="@i.Id" onsubmit="return confirm('Delete this invoice?');"><button class="btn btn-sm btn-outline-danger">Delete</button></form></div></td></tr>}
 </tbody></table></div>
</div>
<div class="modal fade" id="invoiceModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-lg modal-dialog-centered"><div class="modal-content"><form method="post" asp-page-handler="Save"><div class="modal-header"><h5 class="modal-title" id="invoiceModalTitle">Add Invoice</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body row g-2"><input type="hidden" asp-for="Input.Id" id="invoice-id" /><div class="col-md-6"><label class="form-label">Invoice Number</label><input asp-for="Input.InvoiceNumber" id="invoice-invoicenumber" class="form-control" /></div><div class="col-md-6"><label class="form-label">Due Date</label><input asp-for="Input.DueDate" type="date" id="invoice-duedate" class="form-control" /></div><div class="col-md-6"><label class="form-label">Quote</label><select asp-for="Input.QuoteId" id="invoice-quoteid" class="form-select"><option value="">Select quote</option>@foreach (var q in Model.Quotes){<option value="@q.Id">@q.QuoteNumber</option>}</select></div><div class="col-md-6"><label class="form-label">Contact</label><select asp-for="Input.ContactId" id="invoice-contactid" class="form-select"><option value="">Select contact</option>@foreach (var c in Model.Contacts){<option value="@c.Id">@c.FirstName @c.LastName</option>}</select></div><div class="col-md-6"><label class="form-label">Total Amount</label><input asp-for="Input.TotalAmount" id="invoice-totalamount" class="form-control" /></div><div class="col-md-6"><label class="form-label">Paid Amount</label><input asp-for="Input.PaidAmount" id="invoice-paidamount" class="form-control" /></div></div><div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-crm">Save</button></div></form></div></div></div>
@section Scripts {
<script>
function openAddModal(){document.getElementById('invoiceModalTitle').textContent='Add Invoice';['id','invoicenumber','quoteid','contactid','totalamount','paidamount','duedate'].forEach(x=>document.getElementById('invoice-'+x).value='');}
function openEditModal(btn){document.getElementById('invoiceModalTitle').textContent='Edit Invoice';['id','invoicenumber','quoteid','contactid','totalamount','paidamount','duedate'].forEach(x=>document.getElementById('invoice-'+x).value=btn.dataset[x]||'');}
</script>
}
