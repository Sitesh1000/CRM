@page "/admin/roles/list"
@model Crm.Web.Pages.Admin.RolesModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@{ ViewData["Title"] = "Roles"; }

<div class="crm-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">Roles List</h4>
        <button class="btn btn-crm" type="button" data-bs-toggle="modal" data-bs-target="#roleModal" onclick="openAddModal()">Add Role</button>
    </div>

    <div class="table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Name</th><th>Users</th><th style="width:220px">Actions</th></tr></thead>
            <tbody>
            @foreach (var r in Model.Roles)
            {
                var count = Model.UserCounts.TryGetValue(r.Id, out var c) ? c : 0;
                <tr>
                    <td>@r.Name</td>
                    <td>@count</td>
                    <td>
                        <div class="d-flex gap-2">
                            <a class="btn btn-sm btn-outline-primary" href="/admin/roles/details/@r.Id">Details</a>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#roleModal" data-id="@r.Id" data-name="@r.Name" onclick="openEditModal(this)">Edit</button>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@r.Id" onsubmit="return confirm('Delete this role?');"><button class="btn btn-sm btn-outline-danger">Delete</button></form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="roleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" asp-page-handler="Save">
                <div class="modal-header"><h5 class="modal-title" id="roleModalTitle">Add Role</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body">
                    <input type="hidden" asp-for="Input.Id" id="role-id" />
                    <label class="form-label">Role Name</label>
                    <input asp-for="Input.Name" id="role-name" class="form-control" required />
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-crm">Save</button></div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function openAddModal(){document.getElementById('roleModalTitle').textContent='Add Role';document.getElementById('role-id').value='';document.getElementById('role-name').value='';}
function openEditModal(btn){document.getElementById('roleModalTitle').textContent='Edit Role';document.getElementById('role-id').value=btn.dataset.id||'';document.getElementById('role-name').value=btn.dataset.name||'';}
</script>
}
