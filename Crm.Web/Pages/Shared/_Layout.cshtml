@using Crm.Infrastructure.Identity
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@{
    var currentUser = User.Identity?.IsAuthenticated == true
        ? await UserManager.GetUserAsync(User)
        : null;
    var showAdminMenu = currentUser is not null && await UserManager.IsInRoleAsync(currentUser, "Admin");
    var profileName = !string.IsNullOrWhiteSpace(currentUser?.DisplayName)
        ? currentUser!.DisplayName
        : currentUser?.UserName ?? "User";
    var nameParts = profileName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    var profileFirstName = nameParts.Length > 0 ? nameParts[0] : profileName;
    var profileInitial = nameParts.Length >= 2
        ? string.Concat(nameParts[0][0], nameParts[1][0]).ToUpperInvariant()
        : profileName.Substring(0, 1).ToUpperInvariant();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Orbit CRM</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="crm-shell">
    <aside class="crm-sidebar">
        <a class="brand" href="/Dashboard">Orbit CRM</a>
        <nav class="crm-nav">
            <a href="/Dashboard">Dashboard</a>
            <a href="/companies/list">Companies</a>
            <a href="/contacts/list">Contacts</a>
            <a href="/leads/list">Leads</a>
            <a href="/Deals/Pipeline">Pipeline</a>
            <a href="/quotes/list">Quotes</a>
            <a href="/invoices/list">Invoices</a>
            <a href="/activities/list">Activities</a>
            <a href="/Contacts/Timeline">Timeline</a>
            @if (showAdminMenu)
            {
                <a href="/admin/users/list">Users</a>
                <a href="/admin/roles/list">Roles</a>
            }
        </nav>
    </aside>

    <main class="crm-main">
        <header class="crm-topbar">
            <div class="small text-muted">Customer Relationship Platform</div>
            <div class="d-flex align-items-center gap-3">
                @if (currentUser is not null)
                {
                    <div class="profile-wrap" title="@profileName">
                        <div class="profile-avatar">@profileInitial</div>
                        <div class="profile-name">@profileFirstName</div>
                    </div>
                }
                <form method="post" asp-page="/Privacy" asp-page-handler="Logout">
                    <button class="btn btn-sm btn-outline-secondary" type="submit">Logout</button>
                </form>
            </div>
        </header>
        <section class="crm-content">
            @RenderBody()
        </section>
    </main>
</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

