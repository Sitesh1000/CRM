@page "/deals/details/{id:guid}"
@model Crm.Web.Pages.Deals.DetailsModel
@{
    ViewData["Title"] = "Deal Details";
}

@if (Model.Deal is null)
{
    <div class="crm-card">Deal not found.</div>
}
else
{
    <div class="crm-card mb-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h4 class="mb-0">@Model.Deal.Title</h4>
            <a class="btn btn-outline-secondary btn-sm" href="/deals/pipeline">Back to Pipeline</a>
        </div>
        <div class="row g-2">
            <div class="col-md-4"><strong>Stage:</strong> @Model.Deal.Stage</div>
            <div class="col-md-4"><strong>Amount:</strong> @Model.Deal.Amount.ToString("C")</div>
            <div class="col-md-4"><strong>Expected Close:</strong> @Model.Deal.ExpectedCloseDate?.ToString("dd MMM yyyy")</div>
            <div class="col-md-6"><strong>Contact:</strong> @Model.Deal.Contact?.FirstName @Model.Deal.Contact?.LastName</div>
            <div class="col-md-6"><strong>Lead:</strong> @Model.Deal.Lead?.Name</div>
        </div>
    </div>

    <div class="crm-card mb-3">
        <h5>Quotes</h5>
        <ul class="mb-0">
            @foreach (var q in Model.Quotes)
            {
                <li>@q.QuoteNumber - @q.TotalAmount.ToString("C")</li>
            }
        </ul>
    </div>

    <div class="crm-card">
        <h5>Activities</h5>
        <ul class="mb-0">
            @foreach (var a in Model.Activities)
            {
                <li>@a.Type - @a.Description</li>
            }
        </ul>
    </div>
}
